{
  "manifest_version": 3,
  "name": "Caliber — Chat Prompts",
  "version": "1.2.2",
  "description": "Pastes honesty and calibration prompts into ChatGPT, Claude, Gemini, Perplexity—not a confidence overlay. Unrelated to store apps named “Caliber AI”.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["shared/defaults.js", "content/content.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Caliber — open a supported chat site",
    "default_popup": "popup.html"
  }
}
