{
  "manifest_version": 3,
  "name": "Caliber AI - ai self grade assistant",
  "version": "1.3.0",
  "description": "Unpacked prompt assistant: pastes self-grade and honesty snippets into ChatGPT, Claude, Gemini, Perplexity. Not the Chrome Web Store “Caliber AI” overlay app.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["shared/defaults.js", "content/content.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Caliber AI — self-grade prompts",
    "default_popup": "popup.html"
  }
}
